# Shared
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_KEY=base64:replace-me

# MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ocer_dns
DB_USERNAME=root
DB_PASSWORD=smart_dns_dev_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PASSWORD_FILE=
DB_TABLE_PREFIX=dns_

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# ClickHouse
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=smart_dns
CLICKHOUSE_USERNAME=smart_dns
CLICKHOUSE_PASSWORD=smart_dns_dev_password

# NATS
NATS_URL=nats://127.0.0.1:4222

# Internal API security
INTERNAL_HMAC_KEY_ID=portal-web
INTERNAL_HMAC_SECRET=replace-with-random-secret
DNS_CONSOLE_URL=http://localhost:8081

# Resolver Agent
# 凭据不再通过 bootstrap token 自助注册；由管理员在 console 后台预签发后写入 configs/server.yaml
# RESOLVER_NODE_NAME 仅作日志 / 监控标识，不再作为节点注册凭据
RESOLVER_NODE_NAME=resolver-local-01
RESOLVER_REGION=local
RESOLVER_CONSOLE_URL=http://localhost:8081
RESOLVER_HEARTBEAT_INTERVAL=30s
RESOLVER_CONFIG_POLL_INTERVAL=30s

# DNS listener for local dev; use high ports if not root
RESOLVER_LISTEN_UDP=:1053
RESOLVER_LISTEN_TCP=:1053
RESOLVER_LISTEN_DOH=:8443
RESOLVER_LISTEN_DOT=:8853

