{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QueryLogBatch",
  "type": "object",
  "required": [
    "batch_id",
    "node_id",
    "sent_at",
    "items"
  ],
  "properties": {
    "batch_id": {
      "type": "string"
    },
    "node_id": {
      "type": "string"
    },
    "sent_at": {
      "type": "string",
      "format": "date-time"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "type": "object",
        "required": [
          "event_id",
          "timestamp",
          "profile_id",
          "query_name",
          "query_type",
          "action",
          "latency_ms",
          "node_id",
          "profile_version",
          "user_id"
        ],
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 8,
            "maxLength": 120
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "profile_id": {
            "type": "string"
          },
          "user_id": {
            "type": "string"
          },
          "team_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "device_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "query_name": {
            "type": "string",
            "maxLength": 253
          },
          "query_type": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "allowed",
              "blocked",
              "rewritten",
              "error"
            ]
          },
          "reason": {
            "type": "string"
          },
          "category": {
            "type": [
              "string",
              "null"
            ]
          },
          "rule_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "latency_ms": {
            "type": "integer",
            "minimum": 0,
            "maximum": 65535
          },
          "upstream": {
            "type": [
              "string",
              "null"
            ]
          },
          "rcode": {
            "type": "string"
          },
          "client_ip_hash": {
            "type": [
              "string",
              "null"
            ]
          },
          "profile_version": {
            "type": "integer",
            "minimum": 0
          },
          "node_id": {
            "type": "string"
          },
          "node_region": {
            "type": [
              "string",
              "null"
            ]
          },
          "node_country": {
            "type": [
              "string",
              "null"
            ]
          },
          "cache_hit": {
            "type": "boolean"
          },
          "protocol": {
            "type": "string",
            "enum": [
              "udp",
              "tcp",
              "doh",
              "dot",
              "doq"
            ]
          },
          "query_name_hash": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
