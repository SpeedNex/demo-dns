APP_NAME="OcerDNS"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8081

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ocer_dns
DB_USERNAME=ocer
DB_PASSWORD=
# Optional secret-file override. If set, takes precedence over DB_PASSWORD.
DB_PASSWORD_FILE=
# Global table prefix applied to every Eloquent query and migration.
# Keep this in sync across all environments that share the same database;
# changing it after the schema is created requires a rename migration.
DB_TABLE_PREFIX=dns_

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@ocerdns.local"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_FAKE=true

VITE_APP_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# ---------- ClickHouse (read-only) ----------
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=ocer_dns
CLICKHOUSE_USER=ocer
CLICKHOUSE_PASSWORD=
CLICKHOUSE_PASSWORD_FILE=
CLICKHOUSE_TIMEOUT=1.5
CLICKHOUSE_CONNECT_TIMEOUT=1.0
CLICKHOUSE_ENABLED=true

# ---------- Control plane (formerly dns-console-web) ----------
# Tokens authenticate resolver, geodns, and the internal in-process call.
# *_FILE takes precedence when set, so secrets can be mounted from the
# Docker secret store. We never log these values.
BOOTSTRAP_SHARED_TOKEN=
BOOTSTRAP_SHARED_TOKEN_FILE=
INTERNAL_SHARED_TOKEN=
INTERNAL_SHARED_TOKEN_FILE=
ADMIN_SHARED_TOKEN=
ADMIN_SHARED_TOKEN_FILE=

# ---------- Resolver node shared-secret ----------
# Optional global HMAC key. Per-node secrets are issued and stored in
# portal-web; this value is used only for the very first install where
# the bootstrap handshake is required. Leave empty in production.
RESOLVER_DEFAULT_HMAC_KEY=
